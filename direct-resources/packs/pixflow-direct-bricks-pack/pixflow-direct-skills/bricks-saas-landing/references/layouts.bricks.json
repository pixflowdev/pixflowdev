      "token_contract": ["section uses var(--background)", "mockup surface uses var(--foreground)", "borders use var(--border)", "surfaces use var(--radius--surface)"],
      "responsive_contract": ["Mockup is full width under hero copy", "Browser sidebar and canvas stack at mobile if needed"],
      "qa_hooks": ["browser_mockup_present", "product_ui_is_editable_blocks", "no_stock_photo_substitution"]
    },
    {
