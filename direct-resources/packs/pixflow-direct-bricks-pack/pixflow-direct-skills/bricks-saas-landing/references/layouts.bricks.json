{
  "type": "direct_skill_bricks_layout_references",
  "version": 1,
  "skill": "bricks-saas-landing",
  "layouts": [
    {
      "key": "saas_sticky_header",
      "section_type": "header",
      "pattern": "saas_sticky_header",
      "purpose": "Clean SaaS navigation with brand, links, and one primary action.",
      "compiler_route": "compile_saas_header",
      "bricks_structure": ["section", "container", "block.nav", "text-basic.brand", "block.links", "button"],
      "required_elements": ["brand", "nav_items", "primary_cta"],
      "class_contract": ["header", "header__container", "header__nav", "header__brand", "header__links", "header__button"],
      "token_contract": ["var(--background)", "var(--foreground)", "var(--border)", "var(--radius--btn)", "max(var(--border--btn), 1px)"],
      "responsive_contract": ["Desktop keeps one row", "Mobile stacks or hides nav before overflow"],
      "qa_hooks": ["header_has_nav", "header_has_primary_cta", "no_mobile_overflow"]
    },
    {
      "key": "hero_centered_browser_mockup",
